# ── API (/apps/api/.env) ──────────────────────────────────────────────────

# Supabase connection string (Session mode, port 5432)
DATABASE_URL=postgresql://postgres.[project]:[password]@aws-0-eu-north-1.pooler.supabase.com:5432/postgres

# Secret injected by Cloudflare Transform Rule → X-CF-Secret header
# Generate: openssl rand -hex 32
CF_SECRET=

# Bearer token for admin API routes
# Generate: openssl rand -hex 32
AUTH_SECRET=

# Frontend origin for CORS (no trailing slash)
ALLOWED_ORIGIN=https://anadinema.dev

PORT=8080

# ── Web (/apps/web/.env) ──────────────────────────────────────────────────

# PUBLIC_ prefix makes this available in Astro client-side code too
PUBLIC_API_URL=https://api.anadinema.dev
