---
import Base from '@/layouts/Base.astro'
import { getPosts } from '@/lib/data'

// When the API is ready, swap this:
// import { fetchPosts } from '@/lib/api'
// const posts = await fetchPosts()
// export const prerender = false

const posts = getPosts()

// Group posts by year
const byYear = posts.reduce<Record<number, typeof posts>>((acc, post) => {
  acc[post.year] ??= []
  acc[post.year].push(post)
  return acc
}, {})

const years = Object.keys(byYear).map(Number).sort((a, b) => b - a)
---

<Base title="writing">
  <div class="page-title"><span class="sl">// </span>writing ✍️</div>
  <p class="page-sub">irregular notes on backend engineering, infrastructure, and tooling</p>

  {years.map((year) => (
    <div class="year-group">
      <div class="year-label">{year}</div>
      <div class="post-list">
        {byYear[year].map((post) => (
          <a class="post-item" href={`/writing/${post.slug}`}>
            <span class="post-title">{post.title}</span>
            <div class="post-meta">
              <span class="post-tag">{post.tag}</span>
              <span class="post-date">{post.date.split(' ')[0]}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  ))}
</Base>

<style>
  .year-group { margin-bottom: 36px; }

  .year-label {
    font-size: 0.73rem;
    color: var(--accent);
    letter-spacing: 0.08em;
    font-weight: 500;
    margin-bottom: 10px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border);
  }
</style>
