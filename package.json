{
  "name": "@anadinema/site",
  "type": "module",
  "version": "0.1.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "npm run build && wrangler dev",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "check": "astro check && biome check",
    "generate-types": "mkdir -p src/generated && wrangler types --path src/generated/worker-configuration.d.ts",
    "deploy": "npm run build && wrangler deploy",
    "ci": "npm run generate-types && npm run check"
  },
  "dependencies": {
    "@lucide/astro": "^1.16.0",
    "astro": "^6.3.5"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/cloudflare": "^13.5.4",
    "@biomejs/biome": "^2.4.13",
    "typescript": "^6.0.3",
    "wrangler": "^4.94.0"
  },
  "overrides": {
    "vite": "^7"
  }
}
