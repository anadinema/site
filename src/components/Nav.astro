---
import { Moon, Sun } from "@lucide/astro";

const path = Astro.url.pathname;

function isActive(href: string) {
  if (href === "/") return path === "/";
  return path.startsWith(href);
}
---

<nav>
  <div class="wrap">
    <a class="nav-logo" href="/"><span class="tilda">~/</span>anadinema</a>

    <div class="nav-center">
      <a href="/blog"      class:list={[{ active: isActive('/blog') }]}>blog</a>
      <a href="/projects"  class:list={[{ active: isActive('/projects') }]}>projects</a>
      <a href="/stack"     class:list={[{ active: isActive('/stack') }]}>stack</a>
      <a href="/lists"     class:list={[{ active: isActive('/lists') }]}>lists</a>
    </div>

    <button class="theme-btn" onclick="window.toggleTheme()" aria-label="Toggle theme">
      <span class="theme-icon theme-icon-sun" aria-hidden="true"><Sun size={16} /></span>
      <span class="theme-icon theme-icon-moon" aria-hidden="true"><Moon size={16} /></span>
    </button>
  </div>
</nav>

<style>
  nav {
    border-bottom: 1px solid var(--border);
    padding: 17px 0;
    position: sticky;
    top: 0;
    background: var(--nav-bg);
    backdrop-filter: blur(10px);
    z-index: 100;
    transition: background 0.25s, border-color 0.25s;
  }

  nav .wrap {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    font-weight: 600;
    font-size: 0.98rem;
    color: var(--text);
    text-decoration: none;
    border: none;
    letter-spacing: 0.01em;
    flex-shrink: 0;
    transition: color 0.15s;
  }

  .nav-logo:hover { color: var(--accent); }
  .nav-logo .tilda  { color: var(--accent); }

  .nav-center {
    display: flex;
    gap: 22px;
  }

  .nav-center a {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.86rem;
    cursor: pointer;
    transition: color 0.15s;
    padding-bottom: 2px;
    border-bottom: 1px solid transparent;
    letter-spacing: 0.02em;
  }

  .nav-center a:hover        { color: var(--text); border: none; }
  .nav-center a.active       { color: var(--accent); border-bottom-color: var(--accent); }

  .theme-btn {
    background: none;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    font-family: inherit;
    font-size: 1rem;
    line-height: 1;
    padding: 0;
    transition: color 0.15s, transform 0.15s;
    display: flex;
    align-items: center;
  }

  .theme-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .theme-icon-sun,
  .theme-icon-moon {
    display: none;
  }

  :global(html[data-theme="dark"]) .theme-icon-sun { display: inline-flex; }
  :global(html[data-theme="dark"]) .theme-icon-moon { display: none; }
  :global(html[data-theme="light"]) .theme-icon-moon { display: inline-flex; }
  :global(html[data-theme="light"]) .theme-icon-sun { display: none; }

  .theme-btn:hover {
    color: var(--accent);
    transform: translateY(-1px);
  }

  @media (max-width: 560px) {
    .nav-center { gap: 14px; }
    .nav-center a { font-size: 0.72rem; }
  }
</style>
