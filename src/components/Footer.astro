---
const year = new Date().getFullYear();
---

<footer>
  <div class="wrap">
    <span>anadinema · stockholm 📍 · {year}</span>
    <span>
      <a href="https://github.com/anadinema" target="_blank" rel="noopener">github</a>
      &nbsp;·&nbsp;
      <a href="https://linkedin.com/in/anadinema" target="_blank" rel="noopener">linkedin</a>
      &nbsp;·&nbsp;
      <a href="/rss.xml">rss</a>
    </span>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--border);
    padding: 24px 0;
    transition: border-color 0.25s;
  }

  footer .wrap {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  footer a {
    color: var(--text-muted);
    text-decoration: none;
    border: none;
    transition: color 0.15s;
  }

  footer a:hover { color: var(--accent); }
</style>
