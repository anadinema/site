---
import Footer from "@/components/Footer.astro";
import Nav from "@/components/Nav.astro";
import "@/styles/global.css";
import Font from "astro/components/Font.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "anadinema",
  description = "backend engineer based in stockholm",
} = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title === 'anadinema' ? 'anadinema' : `${title} · anadinema`}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="anadinema" href="/rss.xml" />
    <Font cssVariable="--font-jetbrains-mono" />
    <style is:inline>
      html, body { margin: 0; min-height: 100%; }
      html { overflow-y: scroll; scrollbar-gutter: stable both-edges; }
      body { min-height: 100vh; display: flex; flex-direction: column; }
      main { flex: 1; }
    </style>

    <!--
      Inline theme script — must run before CSS to prevent flash of wrong theme.
      is:inline keeps Astro from bundling/deferring it.
    -->
    <script is:inline>
      const saved = localStorage.getItem('theme')
      if (saved === 'light') {
        document.documentElement.setAttribute('data-theme', 'light')
      }
    </script>
  </head>
  <body>
    <Nav />
    <main>
      <div class="wrap">
        <slot />
      </div>
    </main>
    <Footer />

    <script>
      declare global {
        interface Window {
          toggleTheme: () => void
        }
      }

      // Theme toggle — wired to the button in Nav.astro
      window.toggleTheme = () => {
        const html = document.documentElement
        const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark'
        html.setAttribute('data-theme', next)
        localStorage.setItem('theme', next)
      }
    </script>
  </body>
</html>
