---

import PhotoStrip from "@/components/PhotoStrip.astro";
import { getCuratedBlogPosts } from "@/data/blog";
import { getStripPhotos } from "@/data/photos";
import Base from "@/layouts/Base.astro";

const posts = await getCuratedBlogPosts();
const photos = getStripPhotos();
---

<Base>
  <!-- Intro -->
  <div class="intro">
    <div class="intro-handle">
      hej<span class="sl">.</span>&nbsp;it's anadi<span class="sl">.</span>&nbsp;<span class="cursor"></span>
    </div>
    <div class="intro-tagline">
      <span class="sl">// </span>senior software engineer · 📍 stockholm, sweden
    </div>

    <div class="intro-body">
      <p>
        I build distributed event driven systems, APIs, CLIs ⚙️. Currently working at
        <a href="https://www.postnord.com" target="_blank" rel="noopener">PostNord</a> 🚚, focused on
        <a href="https://www.postnord.com/integrations/booking-api/" target="_blank" rel="noopener">Booking</a> and
        <a href="https://www.postnord.com/integrations/pre-order-api/" target="_blank" rel="noopener">Location</a>
        services used by customers to submit shipment and logistics details 📦.
      </p>

      <p>
        At work, I choose to mostly build with
        <span class="stack-pair" aria-label="Node.js and TypeScript">
          <img class="stack-icons" src="https://cdn.simpleicons.org/nodedotjs?viewbox=auto&size=16" alt="Node.js" title="Node.js" loading="lazy" />
          <img class="stack-icons" src="https://cdn.simpleicons.org/typescript?viewbox=auto&size=16" alt="TypeScript" title="TypeScript" loading="lazy" />
        </span>
        or
        <span class="stack-pair" aria-label="Java and Quarkus">
          <img class="stack-icons" src="https://cdn.simpleicons.org/openjdk/red?viewbox=auto&size=16" alt="Java" title="Java" loading="lazy" />
          <img class="stack-icons" src="https://cdn.simpleicons.org/quarkus?viewbox=auto&size=16" alt="Quarkus" title="Quarkus" loading="lazy" />
        </span>.
        In personal time, I am experimenting with
        <span class="stack-pair" aria-label="Go and Rust">
          <img class="stack-icons-go" src="https://cdn.simpleicons.org/go?viewbox=auto&size=10" alt="Go" title="Go" loading="lazy" />
          <img class="stack-icons" src="https://cdn.simpleicons.org/rust/red?viewbox=auto&size=16" alt="Rust" title="Rust" loading="lazy" />
        </span>
        for backend, and
        <span class="stack-pair" aria-label="Astro and TypeScript">
          <img class="stack-icons" src="https://cdn.simpleicons.org/astro?viewbox=auto&size=16" alt="Astro" title="Astro" loading="lazy" />
          <img class="stack-icons" src="https://cdn.simpleicons.org/typescript?viewbox=auto&size=16" alt="TypeScript" title="TypeScript" loading="lazy" />
        </span>
        on the frontend. Interested in more of my tech stack? Go to
        <a class="icon-link" href="https://github.com/anadinema" target="_blank" rel="noopener">
          <img class="stack-icons" src="https://cdn.simpleicons.org/github/ec782b?viewbox=auto&size=16" alt="GitHub" title="GitHub" loading="lazy" />
        </a> for more insights.
      </p>
      <p>
        I like systems that are simple, reliable, predictable, easy to debug when things are on 🔥, and still make
        sense a few years later 🧱.
      </p>
      <p>
        Outside work, I spend more time tinkering with hardware, testing CLI tools, contributing
        to open source, or 📝 <a href="/blog">writing</a> things out.
        Happen to click 📸 <a href="/photos">photos</a> too, when I am out travelling — mostly architecture, history, landscape, and abstract shots.
      </p>
    </div>

    <div class="intro-status">
      <span
        class="status-dot"
        aria-hidden="true"
        style="width:5px;height:5px;border-radius:50%;background:#22c55e;box-shadow:0 0 5px rgba(34,197,94,.95);"
      ></span>
      <span>currently: building this site · reading <em>The Almanack of Naval Ravikant</em></span>
    </div>
  </div>

  <!-- Curated blog -->
  <div class="home-blog">
    <div class="home-label">some blog posts</div>
      coming soon....
    <!--<ul class="curated-list">-->
    <!--  {posts.map((post) => (-->
    <!--    <li>-->
    <!--      <a href={`/blog/${post.slug}`}>-->
    <!--        <span class="arrow">→</span>-->
    <!--        {post.title}-->
    <!--        <span class="post-tag">{post.tag}</span>-->
    <!--      </a>-->
    <!--    </li>-->
    <!--  ))}-->
    <!--</ul>-->
    <!--<a class="all-link" href="/blog">all posts →</a>-->
  </div>

  <!-- Photo strip -->
  <PhotoStrip photos={photos} />
</Base>

<style>
  /* ── Intro ── */
  .intro { margin-bottom: 52px; }

  .intro-handle {
    font-size: 2rem;
    font-weight: 600;
    color: var(--text);
    letter-spacing: -0.01em;
    line-height: 1.2;
    margin-bottom: 5px;
    display: flex;
    align-items: center;
  }

  .cursor {
    display: inline-block;
    width: 10px;
    height: 1.8rem;
    background: var(--accent);
    margin-left: 6px;
    opacity: 0.85;
    animation: blink 1.2s step-end infinite;
    border-radius: 1px;
    vertical-align: middle;
  }

  @keyframes blink { 0%, 100% { opacity: 0.85; } 50% { opacity: 0; } }

  .intro-tagline {
    font-size: 0.83rem;
    color: var(--text-muted);
    margin-bottom: 26px;
    letter-spacing: 0.02em;
  }

  .intro-body {
    display: flex;
    flex-direction: column;
    gap: 14px;
    font-size: 0.90rem;
    color: var(--text);
    line-height: 1.95;
    max-width: 590px;
  }

  .intro-body a.icon-link {
    border: none;
    text-decoration: none;
    display: inline-flex;
    vertical-align: middle;
  }

  .stack-pair {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    vertical-align: middle;
    margin: 0 2px;
  }

  .stack-icons {
    display: inline-block;
    height: 16px;
    width: auto;
    vertical-align: middle;
    margin: 0;
    border-radius: 2px;
  }

  .stack-icons-go {
    display: inline-block;
    height: 10px;
    width: auto;
    vertical-align: middle;
    margin: 0;
    border-radius: 2px;
  }

  .intro-status {
    margin-top: 22px;
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-size: 0.78rem;
    color: var(--text-muted);
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-left: 2px solid var(--accent);
    padding: 7px 13px;
    border-radius: 2px;
  }

  .status-dot {
    display: inline-block;
    flex-shrink: 0;
  }

  /* ── Curated blog ── */
  .home-blog { margin-bottom: 52px; }

  .home-label {
    font-size: 0.75rem;
    color: var(--text-muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 14px;
  }

  .curated-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--border);
  }

  .curated-list li { border-bottom: 1px solid var(--border); }

  .curated-list li a {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 0;
    font-size: 0.875rem;
    color: var(--text);
    text-decoration: none;
    border: none;
    transition: color 0.15s;
  }

  .curated-list li a:hover { color: var(--accent); }

  .arrow {
    color: var(--accent-dim);
    flex-shrink: 0;
    transition: color 0.15s, transform 0.15s;
  }

  .curated-list li a:hover .arrow {
    color: var(--accent);
    transform: translateX(2px);
  }

  .post-tag {
    font-size: 0.74rem;
    color: var(--accent-dim);
    background: var(--accent-glow);
    padding: 1px 6px;
    border-radius: 2px;
    border: 1px solid var(--tag-border);
    margin-left: auto;
    flex-shrink: 0;
  }

  .all-link {
    display: inline-block;
    margin-top: 14px;
    font-size: 0.78rem;
    color: var(--text-muted);
    text-decoration: none;
    border: none;
    border-bottom: 1px solid transparent;
    padding-bottom: 1px;
    transition: color 0.15s, border-color 0.15s;
  }

  .all-link:hover {
    color: var(--accent);
    border-bottom-color: var(--accent-dim);
  }

  @media (max-width: 540px) {
    .intro-handle { font-size: 1.5rem; }
  }
</style>
