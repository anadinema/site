---
import { ChevronLeft, ChevronRight, X } from "@lucide/astro";
import { getPhotos } from "@/data/photos";
import Base from "@/layouts/Base.astro";

const photos = getPhotos();
---

<Base title="photos">
  <div class="page-title"><span class="sl">// </span>photos 📸</div>
  <p class="page-sub">landscape, architecture and thoughts — shot on iphone · stockholm & beyond</p>

  <div class="photo-grid">
    {photos.map((photo, index) => (
      <div class:list={['photo-item', { tall: photo.tall }]}>
        <button
          class="photo-open"
          data-index={index}
          data-src={photo.src}
          data-caption={photo.caption}
          data-location={photo.location}
          aria-label={`Open ${photo.caption}`}
        >
          <img
            class="photo-img"
            src={photo.src}
            alt={photo.caption}
            width={photo.width}
            height={photo.height}
            loading="lazy"
            decoding="async"
          />
        </button>
        <div class="photo-caption">
          {photo.caption}
          <span class="photo-location">{photo.location}</span>
        </div>
      </div>
    ))}
  </div>

  <div id="photo-lightbox" class="lightbox" hidden aria-hidden="true">
    <button id="lightbox-close" class="lightbox-close" aria-label="Close photo viewer">
      <X />
    </button>
    <button id="lightbox-prev" class="lightbox-nav lightbox-prev" aria-label="Previous photo">
      <ChevronLeft />
    </button>

    <figure class="lightbox-figure">
      <img id="lightbox-image" class="lightbox-image" src="" alt="" />
      <figcaption id="lightbox-caption" class="lightbox-caption"></figcaption>
    </figure>

    <button id="lightbox-next" class="lightbox-nav lightbox-next" aria-label="Next photo">
      <ChevronRight />
    </button>
  </div>

  <script is:inline>
    const lightbox = document.getElementById('photo-lightbox')
    const image = document.getElementById('lightbox-image')
    const caption = document.getElementById('lightbox-caption')
    const closeBtn = document.getElementById('lightbox-close')
    const prevBtn = document.getElementById('lightbox-prev')
    const nextBtn = document.getElementById('lightbox-next')
    const openButtons = Array.from(document.querySelectorAll('.photo-open'))
    const items = openButtons.map((button) => ({
      src: button.getAttribute('data-src') ?? '',
      caption: button.getAttribute('data-caption') ?? '',
      location: button.getAttribute('data-location') ?? '',
    }))

    let currentIndex = 0

    const render = () => {
      const current = items[currentIndex]
      if (!current) return
      image?.setAttribute('src', current.src)
      image?.setAttribute('alt', current.caption)
      if (caption) {
        caption.textContent = `${current.caption} · ${current.location}`
      }
    }

    const open = (index) => {
      if (!items.length) return
      currentIndex = index
      render()
      if (!lightbox) return
      lightbox.hidden = false
      lightbox.setAttribute('aria-hidden', 'false')
      document.body.style.overflow = 'hidden'
    }

    const close = () => {
      if (!lightbox) return
      lightbox.hidden = true
      lightbox.setAttribute('aria-hidden', 'true')
      document.body.style.overflow = ''
    }

    const prev = () => {
      if (!items.length) return
      currentIndex = (currentIndex - 1 + items.length) % items.length
      render()
    }

    const next = () => {
      if (!items.length) return
      currentIndex = (currentIndex + 1) % items.length
      render()
    }

    openButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const index = Number(button.getAttribute('data-index') ?? '0')
        open(index)
      })
    })

    closeBtn?.addEventListener('click', close)
    prevBtn?.addEventListener('click', prev)
    nextBtn?.addEventListener('click', next)

    lightbox?.addEventListener('click', (event) => {
      if (event.target === lightbox) close()
    })

    window.addEventListener('keydown', (event) => {
      if (!lightbox || lightbox.hidden) return
      if (event.key === 'Escape') close()
      if (event.key === 'ArrowLeft') prev()
      if (event.key === 'ArrowRight') next()
    })
  </script>
</Base>

<style>
  .photo-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
  }

  .photo-item {
    overflow: hidden;
    border-radius: 3px;
    background: var(--bg-2);
    border: 1px solid var(--border);
  }

  .photo-open {
    all: unset;
    display: block;
    width: 100%;
    cursor: zoom-in;
  }

  .photo-item.tall { grid-row: span 2; }

  .photo-item .photo-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    min-height: 200px;
    transition: transform 0.4s ease, filter 0.3s ease;
    filter: saturate(0.85);
  }

  .photo-item.tall .photo-img { min-height: 420px; }

  .photo-item:hover .photo-img {
    transform: scale(1.03);
    filter: saturate(1.05);
  }

  .photo-caption {
    padding: 8px 10px 9px;
    font-size: 0.72rem;
    color: var(--text);
    border-top: 1px solid var(--border);
    line-height: 1.4;
  }

  .photo-location {
    color: var(--text-muted);
    margin-left: 8px;
  }

  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: rgba(0, 0, 0, 0.88);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }

  .lightbox[hidden] {
    display: none;
  }

  .lightbox-figure {
    margin: 0;
    max-width: min(94vw, 1200px);
    max-height: 90vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }

  .lightbox-image {
    max-width: 100%;
    max-height: calc(90vh - 42px);
    object-fit: contain;
    border-radius: 4px;
  }

  .lightbox-caption {
    color: var(--text);
    font-size: 0.8rem;
    letter-spacing: 0.01em;
  }

  .lightbox-close,
  .lightbox-nav {
    all: unset;
    position: fixed;
    color: var(--text-muted);
    cursor: pointer;
    user-select: none;
    line-height: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 999px;
    background: color-mix(in oklab, var(--bg) 75%, transparent);
  }

  .lightbox-close {
    top: 16px;
    right: 18px;
  }

  .lightbox-nav {
    top: 50%;
    transform: translateY(-50%);
    padding: 0;
  }

  .lightbox-close :global(svg),
  .lightbox-nav :global(svg) {
    width: 24px;
    height: 24px;
  }

  .lightbox-prev { left: 14px; }
  .lightbox-next { right: 14px; }

  @media (max-width: 480px) {
    .photo-grid          { grid-template-columns: 1fr; }
    .photo-item.tall     { grid-row: span 1; }
    .photo-item.tall .photo-img { min-height: 240px; }

    .lightbox {
      padding: 8px;
    }

    .lightbox-nav { width: 36px; height: 36px; }
  }
</style>
