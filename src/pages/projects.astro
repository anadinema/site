---
import { getProjects } from "@/data/projects";
import Base from "@/layouts/Base.astro";

const projects = getProjects();
---

<Base title="projects">
  <div class="page-title"><span class="sl">// </span>projects 🛠️</div>
  <p class="page-sub">things I've built, mostly to scratch an itch</p>

  <div class="project-list">
    {projects.map((project) => (
      <div class="project-item">
        <div class="project-header">
          <span class="project-name">{project.name}</span>
          <span class="project-year">{project.year}</span>
        </div>
        <p class="project-desc">{project.longDescription ?? project.description}</p>
        <div class="tag-list">
          {project.tags.map((tag) => <span class="tag">{tag}</span>)}
        </div>
        <div class="project-links">
          {project.github && (
            <a class="ext-link" href={project.github} target="_blank" rel="noopener">github</a>
          )}
          {project.url && (
            <a class="ext-link" href={project.url} target="_blank" rel="noopener">live</a>
          )}
        </div>
      </div>
    ))}
  </div>
</Base>

<style>
  .project-list { display: flex; flex-direction: column; }

  .project-item {
    padding: 26px 0;
    border-bottom: 1px solid var(--border);
  }

  .project-item:first-child { padding-top: 0; }
  .project-item:last-child  { border-bottom: none; }

  .project-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 8px;
  }

  .project-name {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text);
  }

  .project-year {
    font-size: 0.72rem;
    color: var(--text-muted);
    flex-shrink: 0;
    margin-top: 4px;
  }

  .project-desc {
    font-size: 0.855rem;
    color: var(--text-muted);
    line-height: 1.8;
    margin-bottom: 12px;
  }

  .project-links {
    display: flex;
    gap: 18px;
    margin-top: 12px;
  }
</style>
