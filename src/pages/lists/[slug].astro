---
import { getList, getLists } from "@/data/lists";
import Base from "@/layouts/Base.astro";

export async function getStaticPaths() {
  return getLists().map((list) => ({
    params: { slug: list.slug },
  }));
}

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect("/lists");
}

const list = getList(slug);

if (!list) {
  return Astro.redirect("/lists");
}
---

<Base title={list.name}>
  <a class="back-link" href="/lists">← lists</a>

  <div class="page-title"><span class="sl">// </span>{list.emoji} {list.name}</div>
  <p class="page-sub">{list.description}</p>

  <div class="list-entries">
    {list.items.map((item) => (
      <div class:list={['list-entry', `s-${item.status}`]}>
        <div class="entry-name">{item.name}</div>
        <div class="entry-note">{item.note}</div>
        <div class="entry-footer">
          <span class:list={['e-status', item.status]}>{item.status}</span>
          {item.date && <span class="entry-date">{item.date}</span>}
        </div>
      </div>
    ))}
  </div>
</Base>

<style>
  .back-link {
    display: inline-block;
    font-size: 0.80rem;
    color: var(--text-muted);
    margin-bottom: 30px;
    border: none;
    transition: color 0.15s;
  }

  .back-link:hover { color: var(--accent); }

  .list-entries {
    display: flex;
    flex-direction: column;
  }

  .list-entry {
    padding: 15px 0 15px 14px;
    border-bottom: 1px solid var(--border);
    border-left: 2px solid var(--border);
    transition: border-left-color 0.15s;
  }

  .list-entry:last-child  { border-bottom: none; }
  .list-entry.s-want      { border-left-color: var(--accent-dim); }
  .list-entry.s-done      { border-left-color: var(--green); }
  .list-entry.s-maybe     { border-left-color: var(--border-2); }
  .list-entry.s-now       { border-left-color: var(--accent); }
  .list-entry:hover       { border-left-color: var(--accent); }

  .entry-name {
    font-size: 0.88rem;
    color: var(--text);
    font-weight: 500;
    margin-bottom: 4px;
  }

  .entry-note {
    font-size: 0.80rem;
    color: var(--text-muted);
    line-height: 1.7;
  }

  .entry-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 8px;
  }

  .entry-date {
    font-size: 0.68rem;
    color: var(--text-faint);
  }
</style>
